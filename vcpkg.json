{
  "name": "zh-revival",
  "version": "0.1.0",
  "description": "Command and Conquer Generals Zero Hour community revival — open source rebuild",
  "homepage": "https://github.com/zerwonenetwork/zh-revival",
  "license": "GPL-3.0-only",
  "supports": "windows & x86",
  "dependencies": [
    "zlib",
    {
      "name": "openal-soft",
      "platform": "windows"
    },
    {
      "name": "ffmpeg",
      "features": ["avcodec", "avformat", "swscale"],
      "default-features": false,
      "platform": "!mingw"
    },
    "sdl3"
  ]
}
